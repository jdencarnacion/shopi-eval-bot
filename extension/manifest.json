{
  "manifest_version": 3,
  "name": "Shopi Eval Bot",
  "version": "1.0.0",
  "description": "Real-time Shopify Plus sales assist during discovery calls",
  "permissions": ["tabCapture", "offscreen", "storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:*/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shopi Eval Bot"
  }
}
